# 各環境の envs/{env}/backend.tf にコピーして {ACCOUNT_ID} と {ENV} を置換すること

terraform {
  backend "s3" {
    bucket         = "aegis-tfstate-{ENV}-{ACCOUNT_ID}"
    key            = "infra/terraform.tfstate"
    region         = "ap-northeast-1"
    dynamodb_table = "aegis-tflock"
    encrypt        = true
    kms_key_id     = "alias/aws/s3"
  }
}
