# AivisSpeech Engine
AIVIS_ENGINE_URL=http://localhost:10101

# ろてじん Voice Model (Style-Bert-VITS2 JP-Extra, ONNX)
# https://hub.aivisproject.com/aivm-models/80fe2db4-5891-4550-a3f3-dff9a91c0946
VOICE_MODEL_UUID=80fe2db4-5891-4550-a3f3-dff9a91c0946
VOICE_STYLE_NAME=ノーマル

# Video output settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# Font (Noto Sans JP recommended for Japanese telops/subtitles)
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc

# Optional: AI image generation
# Leave empty to use black background only
IMAGE_GEN_BACKEND=
# Supported: "", "openai", "stability"
OPENAI_API_KEY=
STABILITY_API_KEY=

# --------- Daily posting (POSTING.md) ---------
# Target TikTok account (no @ prefix).
TIKTOK_USERNAME=ex_gambler_kazuki

# manual = notify operator with video + caption only (safe, default)
# auto   = drive tiktok-uploader (risky, requires cookies.txt)
POSTING_MODE=manual

# Netscape-format cookies for the TikTok account; only read when
# POSTING_MODE=auto. Export with Cookie-Editor extension.
TIKTOK_COOKIES_PATH=./secrets/cookies.txt

# Discord webhook for success/failure pings (strongly recommended).
DISCORD_WEBHOOK_URL=

# Whether to start the queue with 000 (intro/pinned) or skip to 001.
INCLUDE_INTRO=true
