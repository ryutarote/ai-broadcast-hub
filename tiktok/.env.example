# AivisSpeech Engine
AIVIS_ENGINE_URL=http://localhost:10101

# ろてじん Voice Model (Style-Bert-VITS2 JP-Extra, ONNX)
# https://hub.aivisproject.com/aivm-models/80fe2db4-5891-4550-a3f3-dff9a91c0946
VOICE_MODEL_UUID=80fe2db4-5891-4550-a3f3-dff9a91c0946
VOICE_STYLE_NAME=ノーマル

# Video output settings
VIDEO_WIDTH=1080
VIDEO_HEIGHT=1920
VIDEO_FPS=30

# Font (Noto Sans JP recommended for Japanese telops/subtitles)
FONT_PATH=/usr/share/fonts/opentype/noto/NotoSansCJK-Bold.ttc

# Optional: AI image generation
# Leave empty to use black background only
IMAGE_GEN_BACKEND=
# Supported: "", "openai", "stability"
OPENAI_API_KEY=
STABILITY_API_KEY=
